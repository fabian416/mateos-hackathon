{
  "agents": {
    "defaults": {
      "model": {
        "primary": "${PRIMARY_MODEL}"
      },
      "models": {
        "anthropic/claude-haiku-4-5": {},
        "anthropic/claude-sonnet-4-6": {}
      },
      "workspace": "${HOME}/.openclaw/workspace",
      "heartbeat": {
        "target": "last"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "${TELEGRAM_DM_POLICY}",
      "allowFrom": ["${TELEGRAM_OWNER_ID}"],
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "${TELEGRAM_GROUP_POLICY}",
      "streaming": "partial",
      "network": {
        "autoSelectFamily": false,
        "dnsResultOrder": "ipv4first"
      }
    },
    "whatsapp": {
      "enabled": ${WHATSAPP_ENABLED},
      "dmPolicy": "${WHATSAPP_DM_POLICY}",
      "allowFrom": [${WHATSAPP_ALLOW_FROM}],
      "groupPolicy": "disabled",
      "sendReadReceipts": true,
      "mediaMaxMb": 50,
      "accounts": {
        "default": {
          "enabled": true
        }
      }
    }
  },
  "gateway": {
    "port": ${GATEWAY_PORT},
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_AUTH_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "hooks": {
    "enabled": true
  },
  "skills": {
    "install": {
      "nodeManager": "bun"
    },
    "allowBundled": ["himalaya"]
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  }
}
