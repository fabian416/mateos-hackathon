# === MateOS — Single Container, 7 Agents ===

# LLM
PRIMARY_MODEL=google/gemini-2.5-flash

# Telegram
TELEGRAM_OWNER_ID=your-telegram-user-id
TG_TOKEN_MATEO_CEO=your-bot-token
TG_TOKEN_TROPERO=your-bot-token
TG_TOKEN_DOMADOR=your-bot-token
TG_TOKEN_RASTREADOR=your-bot-token
TG_TOKEN_RELATOR=your-bot-token
TG_TOKEN_PAISANO=your-bot-token
TG_TOKEN_BAQUEANO=your-bot-token

# Twitter/X
TWITTER_ENABLED=true
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret
TWITTER_HANDLE=mateos_ceo
TWEET_SLOTS=09:00,11:00,13:00,16:00,19:00,21:00

# Google Workspace (gog)
GOOGLE_API_KEY=your-google-api-key
GOG_ACCOUNT=your-google-email@gmail.com
GOG_KEYRING_PASSWORD=your-keyring-password

# Gateway
GATEWAY_PORT=18789
GATEWAY_AUTH_TOKEN=your-gateway-auth-token
HOOKS_TOKEN=your-hooks-token
CALENDAR_ID=your-calendar-id@group.calendar.google.com
